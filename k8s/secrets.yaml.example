# KubeLab Secrets Template
# Copy this file to k8s/secrets.yaml and fill in your values.
# k8s/secrets.yaml is gitignored and should never be committed.
#
# To generate base64 values:
#   echo -n "your-password" | base64
---
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: kubelab
type: Opaque
data:
  # base64 of your postgres password
  password: <base64-encoded-password>
  # base64 of: postgresql://kubelab:<password>@postgres:5432/kubelab
  connection-string: <base64-encoded-connection-string>
---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-secret
  namespace: kubelab
type: Opaque
data:
  # base64 of "admin"
  admin-user: YWRtaW4=
  # base64 of your grafana admin password
  admin-password: <base64-encoded-password>

