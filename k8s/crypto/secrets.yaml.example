apiVersion: v1
kind: Secret
metadata:
  name: crypto-credentials
  namespace: kubelab
type: Opaque
stringData:
  # Bitcoin RPC credentials
  # Generate secure passwords: openssl rand -base64 32
  bitcoin-rpc-user: "kubelab"
  bitcoin-rpc-password: "CHANGE_ME_GENERATE_SECURE_PASSWORD"

  # Lightning admin macaroon (base64 encoded)
  # Generate after first LND startup: kubectl exec -n kubelab lightning-0 -- cat /root/.lnd/data/chain/bitcoin/testnet/admin.macaroon | base64
  admin-macaroon: "REPLACE_WITH_BASE64_ENCODED_MACAROON"
